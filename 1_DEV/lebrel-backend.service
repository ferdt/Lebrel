[Unit]
Description=Lebrel FastAPI Backend
After=network.target

[Service]
User=pi
Group=pi
WorkingDirectory=/home/pi/Lebrel/1_DEV
Environment="PATH=/home/pi/Lebrel/1_DEV/venv/bin"
ExecStart=/home/pi/Lebrel/1_DEV/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
